<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Tsuki" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <style name="Theme.Tsuki" parent="Base.Theme.Tsuki">
        <!-- Hilangkan background lilac/indicator saat item nav aktif -->
        <item name="navigationBarItemActiveIndicatorStyle">@style/NavActiveIndicator</item>
    </style>

    <style name="NavActiveIndicator">
        <item name="android:width">0dp</item>
        <item name="android:height">0dp</item>
        <item name="shapeAppearance">@null</item>
        <item name="android:color">@android:color/transparent</item>
    </style>

    <!-- Bottom Navigation label font -->
    <style name="BottomNavTextAppearance" parent="@style/TextAppearance.MaterialComponents.Caption">
        <item name="fontFamily">@font/lato</item>
        <item name="android:fontFamily">@font/lato</item>
        <item name="android:textSize">11sp</item>
    </style>

    <!-- NumberPicker text color override -->
    <style name="NumberPickerStyle">
        <item name="android:textColorPrimary">@color/navy</item>
        <item name="android:textColor">@color/navy</item>
    </style>
    <style name="DayHeader">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:fontFamily">@font/lato</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/gray</item>
        <item name="android:textSize">12sp</item>
        <item name="android:paddingBottom">4dp</item>
    </style>
</resources>