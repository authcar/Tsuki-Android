<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:context=".ChoiceActivity">

    <!-- Pink top half -->
    <View
        android:id="@+id/pinkTop"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_pink_gradient_rounded"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0"
        app:layout_constraintHeight_percent="0.55" />

    <!-- Back button -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="@dimen/spacing_lg"
        android:layout_marginTop="@dimen/spacing_lg"
        android:background="@drawable/bg_circle_white"
        android:contentDescription="Back"
        android:padding="@dimen/spacing_xs"
        android:src="@drawable/ic_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:id="@+id/scrollCard"
        android:layout_width="0dp"
        android:layout_height="450dp"
        android:layout_marginStart="@dimen/card_margin_horizontal"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="@dimen/card_margin_horizontal"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_white_card"
        android:fillViewport="false"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/btnBack">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/card_padding"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/lato_bold"
                android:textAlignment="center"
                android:text="Start Today"
                android:textColor="@color/navy"
                android:textSize="@dimen/text_title" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/lato"
                android:text="To access your account"
                android:textColor="@color/gray"
                android:textSize="@dimen/text_subtitle"
                android:layout_marginTop="@dimen/spacing_md"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:background="@drawable/signupbuttongoogle"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_margin="10dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_google"
                        android:contentDescription="Google"
                        android:layout_marginRight="20dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:fontFamily="@font/lato"
                        android:text="Continue with Google"
                        android:textColor="@color/navy"
                        android:textSize="@dimen/text_button" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:background="@drawable/signupbuttongoogle"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:paddingStart="10dp"
                    android:layout_margin="10dp"
                    android:paddingEnd="10dp">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_apple"
                        android:layout_marginRight="20dp"
                        android:contentDescription="Apple" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:fontFamily="@font/lato"
                        android:text="Continue with Apple"
                        android:textColor="@color/navy"
                        android:textSize="@dimen/text_button"
                        />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:background="@drawable/signupbuttongoogle"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:paddingStart="16dp"
                    android:layout_margin="10dp"
                    android:paddingEnd="16dp">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_facebook"
                        android:contentDescription="Facebook"
                        android:layout_marginRight="20dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:fontFamily="@font/lato"
                        android:text="Continue with Facebook"
                        android:textColor="@color/navy"
                        android:textSize="@dimen/text_button" />
                </LinearLayout>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnSignUp"
                android:layout_margin="10dp"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:background="@drawable/bg_signup_button"
                android:fontFamily="@font/lato_bold"
                android:textColor="#FFFFFF"
                android:text="Sign up"
                android:textAllCaps="false"
                android:layout_marginTop="@dimen/spacing_md" />

            <androidx.appcompat.widget.AppCompatButton
                android:layout_width="wrap_content"
                android:layout_height="@dimen/button_height"
                android:background="@drawable/signupbuttongoogle"
                android:fontFamily="@font/lato_bold"
                android:textColor="@color/navy"
                android:text="Sign in"
                android:textAllCaps="false"
                android:layout_marginTop="@dimen/spacing_md" />

















        </LinearLayout>


    </ScrollView>




</androidx.constraintlayout.widget.ConstraintLayout>