<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:context=".SignUpChoiceActivity">

    <View
        android:id="@+id/pinkTop"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_pink_gradient_rounded"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0"
        app:layout_constraintHeight_percent="0.55" />

    <!-- Back button -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="@dimen/spacing_lg"
        android:layout_marginTop="@dimen/spacing_lg"
        android:background="@drawable/bg_circle_white"
        android:contentDescription="Back"
        android:padding="@dimen/spacing_xs"
        android:src="@drawable/ic_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Floating white card centered -->
    <ScrollView
        android:id="@+id/scrollCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/card_margin_horizontal"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="@dimen/card_margin_horizontal"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_white_card"
        android:fillViewport="false"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/btnBack">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/card_padding">

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/lato_bold"
                android:text="Sign Up"
                android:textColor="@color/navy"
                android:textSize="@dimen/text_title" />

            <!-- Subtitle -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:fontFamily="@font/lato"
                android:text="Join now to track your cycle."
                android:textColor="@color/gray"
                android:textSize="@dimen/text_subtitle" />

            <!-- Full Name label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:fontFamily="@font/lato_bold"
                android:text="Full Name"
                android:textColor="@color/navy"
                android:textSize="@dimen/text_label" />

            <!-- Full Name field -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputFullName"
                style="@style/Widget.Material3.AutoCompleteTextView.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                app:hintEnabled="false"
                app:boxCornerRadiusBottomEnd="@dimen/input_corner_radius"
                app:boxCornerRadiusBottomStart="@dimen/input_corner_radius"
                app:boxCornerRadiusTopEnd="@dimen/input_corner_radius"
                app:boxCornerRadiusTopStart="@dimen/input_corner_radius"
                app:boxStrokeColor="@color/gray"
                app:boxStrokeWidth="0.7dp"
                app:boxStrokeWidthFocused="1dp"
                app:startIconDrawable="@drawable/user"
                app:startIconScaleType="centerInside"
                app:startIconTint="@color/gray">

                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/lato"
                    android:hint="Full Name"
                    android:textColor="@color/navy"
                    android:textColorHint="@color/gray"
                    android:textSize="@dimen/text_body" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Email label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:fontFamily="@font/lato_bold"
                android:text="Email"
                android:textColor="@color/navy"
                android:textSize="@dimen/text_label" />

            <!-- Email field -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputEmail"
                style="@style/Widget.Material3.AutoCompleteTextView.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                app:hintEnabled="false"
                app:boxCornerRadiusBottomEnd="@dimen/input_corner_radius"
                app:boxCornerRadiusBottomStart="@dimen/input_corner_radius"
                app:boxCornerRadiusTopEnd="@dimen/input_corner_radius"
                app:boxCornerRadiusTopStart="@dimen/input_corner_radius"
                app:boxStrokeColor="@color/gray"
                app:boxStrokeWidth="0.7dp"
                app:boxStrokeWidthFocused="1dp"
                app:startIconDrawable="@drawable/email"
                app:startIconScaleType="centerInside"
                app:startIconTint="@color/gray">

                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/lato"
                    android:hint="Email"
                    android:inputType="textEmailAddress"
                    android:textColor="@color/navy"
                    android:textColorHint="@color/gray"
                    android:textSize="@dimen/text_body" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Password label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/lato_bold"
                android:text="Password"
                android:textColor="@color/navy"
                android:textSize="@dimen/text_label" />

            <!-- Password field -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputPassword"
                style="@style/Widget.Material3.AutoCompleteTextView.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                app:hintEnabled="false"
                app:boxCornerRadiusBottomEnd="@dimen/input_corner_radius"
                app:boxCornerRadiusBottomStart="@dimen/input_corner_radius"
                app:boxCornerRadiusTopEnd="@dimen/input_corner_radius"
                app:boxCornerRadiusTopStart="@dimen/input_corner_radius"
                app:boxStrokeColor="@color/gray"
                app:boxStrokeWidth="0.7dp"
                app:boxStrokeWidthFocused="1dp"
                app:endIconMode="password_toggle"
                app:startIconDrawable="@drawable/lock"
                app:startIconTint="@color/gray"
                app:startIconScaleType="centerInside">

                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/lato"
                    android:hint="Password"
                    android:inputType="textPassword"
                    android:textColor="@color/navy"
                    android:textColorHint="@color/gray"
                    android:textSize="@dimen/text_body" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Terms checkbox -->
            <CheckBox
                android:id="@+id/checkTerms"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:buttonTint="@color/navy"
                android:fontFamily="@font/lato"
                android:text="I agree to Tsuki Terms &amp; Conditions."
                android:textColor="@color/gray"
                android:textSize="@dimen/text_body" />

            <!-- Sign Up button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnSignUp"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginTop="@dimen/spacing_lg"
                android:background="@drawable/bg_signup_button"
                android:fontFamily="@font/lato"
                android:text="Sign up"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="@dimen/text_button" />

            <!-- Or continue with -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/spacing_lg"
                android:fontFamily="@font/lato"
                android:text="Or continue with"
                android:textColor="@color/navy"
                android:textSize="@dimen/text_body" />

            <!-- Social buttons -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/spacing_md"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btnGoogle"
                    android:layout_width="@dimen/social_button_size"
                    android:layout_height="@dimen/social_button_size"
                    android:background="@drawable/bg_social_button"
                    android:contentDescription="Sign in with Google"
                    android:padding="10dp"
                    android:src="@drawable/ic_google" />

                <ImageButton
                    android:id="@+id/btnApple"
                    android:layout_width="@dimen/social_button_size"
                    android:layout_height="@dimen/social_button_size"
                    android:layout_marginStart="@dimen/spacing_md"
                    android:background="@drawable/bg_social_button"
                    android:contentDescription="Sign in with Apple"
                    android:padding="10dp"
                    android:src="@drawable/ic_apple" />

                <ImageButton
                    android:id="@+id/btnFacebook"
                    android:layout_width="@dimen/social_button_size"
                    android:layout_height="@dimen/social_button_size"
                    android:layout_marginStart="@dimen/spacing_md"
                    android:background="@drawable/bg_social_button"
                    android:contentDescription="Sign in with Facebook"
                    android:padding="10dp"
                    android:src="@drawable/ic_facebook" />

            </LinearLayout>

            <!-- Sign in link -->
            <TextView
                android:id="@+id/tvSignIn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/spacing_lg"
                android:fontFamily="@font/lato"
                android:textSize="@dimen/text_body" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
